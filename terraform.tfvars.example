# terraform.tfvars.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to terraform.tfvars for local development
# NEVER commit terraform.tfvars — it contains secrets
# In CI/CD, variables are injected via GitHub Actions secrets
# ─────────────────────────────────────────────────────────────────────────────

aws_region           = "us-east-1"
project              = "openclaw-exp"
vpc_cidr             = "10.0.0.0/16"
instance_type_api    = "t3.small"
instance_type_ollama = "t3.large"
inbox_site_url       = "https://your-s3-bucket.s3.amazonaws.com/inbox/index.html"
messaging_api_domain = "api.telegram.org"

# ── Secrets — fill in locally, never commit ───────────────────────────────────
anthropic_api_key = "sk-ant-..."
openai_api_key    = "sk-..."
